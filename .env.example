# =============================================================================
# .env.example — copy to .env for local development
#
#   cp .env.example .env
#
# All values here are safe defaults for Docker Compose development.
# Do NOT use these in production.
# =============================================================================

# Application
APP_ENV=local
APP_KEY=           # generate with: openssl rand -base64 32
APP_DOMAIN=localhost
APP_URL=http://localhost

# Database (matches db service defaults in docker-compose.yml)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=my_app

# Redis (required when running the worker or full profile)
REDIS_URL=redis://redis:6379
