# =============================================================================
# .env.prod.example — copy to .env.prod and fill in all values before deploy
#
#   cp .env.prod.example .env.prod
#   # then edit .env.prod with real secrets
#
# NEVER commit .env.prod to version control.
# =============================================================================

# Application
APP_ENV=production
APP_KEY=           # REQUIRED — generate with: openssl rand -base64 32
APP_DOMAIN=example.com

# Database
DB_USER=strav
DB_PASSWORD=       # use a strong random password
DB_DATABASE=strav_prod

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=    # use a strong random password
